# Azure OpenAI (https://portal.azure.com — Azure OpenAI resource → Keys and Endpoint)
AZURE_OPENAI_API_KEY=
# e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# The deployment name you created in Azure OpenAI Studio (NOT the base model name)
AZURE_OPENAI_DEPLOYMENT=
# Optional — defaults to 2024-10-21
AZURE_OPENAI_API_VERSION=2024-10-21

ELEVENLABS_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Sheets API — share the spreadsheet with the service account email (Editor)
# Columns (row 1): id, client, topic, category, script, storyboard, prompts, voiceover_direction, voiceover_audio_url, voice_id, status
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Worksheet TAB name (click the tab at the BOTTOM of the spreadsheet — often still "Sheet1").
# This is NOT the document title shown in the browser tab / file name at the top.
# Rename the bottom tab to "Scripts" if you want, or set this to match it (e.g. Sheet1).
GOOGLE_SHEETS_TAB_NAME=Sheet1
